# ────────────────────────────────────────────
# FactChecker Model 3 - Environment Variables
# ────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# For production, use Google Secret Manager instead.

# ── App-level API key ──────────────────────
# Every request (except /health) must include this in the X-API-Key header.
# Generate any strong random string (e.g. `openssl rand -hex 32`).
APP_API_KEY=your-app-api-key-here

# ── LLM API keys ──────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here
OPENAI_API_KEY=your-openai-api-key-here

# ── LLM model names (optional, defaults shown) ──
# GEMINI_MODEL=gemini-1.5-flash
# OPENAI_MODEL=gpt-4o-mini

# ── Firebase ──────────────────────────────
# Path to your Firebase service account JSON file.
# Download from: Firebase Console → Project Settings → Service Accounts → Generate New Private Key
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json

# ── Google Cloud (optional, for Secret Manager) ──
# Only needed if you want to pull secrets from GCP Secret Manager.
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# ── Server ────────────────────────────────
# HOST=0.0.0.0
# PORT=8000

# ── CORS ──────────────────────────────────
# Comma-separated list of allowed origins. Use * for development.
# ALLOWED_ORIGINS=http://localhost:3000,https://your-app.com
